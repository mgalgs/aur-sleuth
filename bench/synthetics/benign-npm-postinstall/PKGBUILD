# Maintainer: Test User <test@example.com>
pkgname=bench-npm-postinstall
pkgver=1.0.0
pkgrel=1
pkgdesc="Benchmark test: Node.js package with legitimate postinstall hook"
arch=('x86_64')
url="https://github.com/example/bench-npm"
license=('MIT')
depends=('nodejs')
source=("package.json" "setup.js")
sha256sums=('SKIP' 'SKIP')

build() {
    cd "${srcdir}"
    node setup.js
}

package() {
    install -Dm644 "${srcdir}/package.json" "${pkgdir}/usr/lib/bench-npm/package.json"
    install -Dm644 "${srcdir}/setup.js" "${pkgdir}/usr/lib/bench-npm/setup.js"
}
